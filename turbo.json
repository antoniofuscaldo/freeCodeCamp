{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    ".nvmrc",
    "eslint.config.js",
    ".prettierrc.mjs",
    "pyproject.toml"
  ],
  "tasks": {
    "repo:lint": {
      "outputs": []
    },
    "repo:lint:fix": {
      "outputs": [],
      "cache": false
    },
    "repo:format": {
      "outputs": [],
      "cache": false
    },
    "repo:format:check": {
      "outputs": []
    },
    "clean:all": {
      "cache": false
    },
    "clean:build": {
      "cache": false
    },
    "clean:coverage": {
      "cache": false
    },
    "clean:dist": {
      "cache": false
    },
    "clean:node_modules": {
      "cache": false
    }
  }
}
