root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false


# Python files
[*.py]
indent_size = 4

# Batch and PowerShell files (Windows)
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Package files
[{package.json,package-lock.json}]
indent_size = 2

