{
  "name": "freecodecamp",
  "type": "module",
  "version": "2.0.0",
  "description": "My freecodecamp certifications collection.",
  "author": {
    "name": "Antonio Fuscaldo",
    "email": "antoniofuscaldo.dev@gmail.com",
    "url": "https://github.com/antoniofuscaldo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp"
  },
  "homepage": "https://github.com/antoniofuscaldo/freeCodeCamp",
  "bugs": {
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp/issues"
  },
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "freecodecamp",
    "certifications",
    "javascript",
    "python"
  ],
  "engines": {
    "node": ">=24.16.0 <25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all",
    "last 2 versions"
  ],
  "scripts": {
    "clean:all": "pnpm run clean:build && pnpm run clean:coverage && pnpm run clean:dist && pnpm run clean:node_modules",
    "clean:build": "rimraf build",
    "clean:coverage": "rimraf coverage",
    "clean:dist": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "format": "turbo run repo:format --continue --cache-dir=.turbo",
    "format:check": "turbo run repo:format:check --continue --cache-dir=.turbo",
    "format:check:javascript": "prettier . --check",
    "format:check:python": ".venv/bin/python -m ruff format . --check",
    "format:javascript": "prettier . --write",
    "format:python": ".venv/bin/python -m ruff format .",
    "lint": "turbo run repo:lint --continue --cache-dir=.turbo",
    "lint:fix": "turbo run repo:lint:fix --continue --cache-dir=.turbo",
    "lint:fix:javascript": "pnpm run lint:javascript -- --fix",
    "lint:fix:python": ".venv/bin/python -m ruff check . --fix",
    "lint:javascript": "eslint . --ext .js,.mjs,.cjs,.jsx,.ts,.tsx --cache",
    "lint:python": ".venv/bin/python -m ruff check .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "rebuild": "pnpm run clean:all && pnpm install",
    "repo:format": "pnpm run format:javascript && pnpm run format:python",
    "repo:format:check": "pnpm run format:check:javascript && pnpm run format:check:python",
    "repo:lint": "pnpm run lint:javascript && pnpm run lint:python",
    "repo:lint:fix": "pnpm run lint:fix:javascript && pnpm run lint:fix:python",
    "turbo:clean": "turbo run clean:all --continue --cache-dir=.turbo",
    "turbo:format": "pnpm run format",
    "turbo:format:check": "pnpm run format:check",
    "turbo:lint": "pnpm run lint",
    "turbo:lint:fix": "pnpm run lint:fix",
    "turbo:pre-commit": "pnpm run lint-staged",
    "turbo:pre-push": "pnpm run lint && pnpm run format:check"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "smol-toml": "^1.6.1",
    "vite": "^7.3.2",
    "yaml": "^2.8.3"
  },
  "contributors": [
    {
      "name": "Antonio Fuscaldo",
      "email": "antoniofuscaldo.dev@gmail.com"
    }
  ]
}
