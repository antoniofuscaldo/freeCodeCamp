{
  "name": "freecodecamp",
  "type": "module",
  "version": "2.0.0",
  "description": "My freecodecamp certifications collection.",
  "author": {
    "name": "Antonio Fuscaldo",
    "email": "antoniofuscaldo.dev@gmail.com",
    "url": "https://github.com/antoniofuscaldo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp"
  },
  "homepage": "https://github.com/antoniofuscaldo/freeCodeCamp",
  "bugs": {
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp/issues"
  },
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "freecodecamp",
    "certifications",
    "javascript",
    "python"
  ],
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all",
    "last 2 versions"
  ],
  "scripts": {
    "clean:all": "pnpm run clean:build && pnpm run clean:coverage && pnpm run clean:dist && pnpm run clean:node_modules",
    "clean:build": "rimraf build",
    "clean:coverage": "rimraf coverage",
    "clean:dist": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "lint": "eslint . --ext .js,.mjs,.cjs,.jsx,.ts,.tsx --cache",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "rebuild": "pnpm run clean:all && pnpm install"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "smol-toml": "^1.6.1",
    "vite": "^7.3.2",
    "yaml": "^2.8.3"
  },
  "contributors": [
    {
      "name": "Antonio Fuscaldo",
      "email": "antoniofuscaldo.dev@gmail.com"
    }
  ]
}
