{
  "name": "freecodecamp",
  "type": "module",
  "version": "2.0.0",
  "description": "My freecodecamp certifications collection.",
  "author": {
    "name": "Antonio Fuscaldo",
    "email": "antoniofuscaldo.dev@gmail.com",
    "url": "https://github.com/antoniofuscaldo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp"
  },
  "homepage": "https://github.com/antoniofuscaldo/freeCodeCamp",
  "bugs": {
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp/issues"
  },
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "freecodecamp",
    "certifications",
    "javascript",
    "python"
  ],
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all",
    "last 2 versions"
  ],
  "scripts": {
    "clean:all": "pnpm run clean:build && pnpm run clean:coverage && pnpm run clean:dist && pnpm run clean:node_modules",
    "clean:build": "rimraf build",
    "clean:coverage": "rimraf coverage",
    "clean:dist": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "py:check": "pnpm run py:lint && pnpm run py:format:check",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --ext .js,.mjs,.cjs,.jsx,.ts,.tsx --cache",
    "lint:fix": "pnpm run lint -- --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "py:format": ".venv/bin/python -m ruff format .",
    "py:format:check": ".venv/bin/python -m ruff format . --check",
    "py:lint": ".venv/bin/python -m ruff check .",
    "py:lint:fix": ".venv/bin/python -m ruff check . --fix",
    "rebuild": "pnpm run clean:all && pnpm install",
    "turbo:clean": "turbo run clean:all --continue --cache-dir=.turbo",
    "turbo:format": "turbo run format --continue --cache-dir=.turbo",
    "turbo:format:check": "turbo run format:check --continue --cache-dir=.turbo",
    "turbo:lint": "turbo run lint --continue --cache-dir=.turbo",
    "turbo:lint:fix": "turbo run lint:fix --continue --cache-dir=.turbo",
    "turbo:pre-commit": "turbo run lint format:check --continue --cache-dir=.turbo",
    "turbo:pre-push": "turbo run lint format:check --cache-dir=.turbo"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "smol-toml": "^1.6.1",
    "vite": "^7.3.2",
    "yaml": "^2.8.3"
  },
  "contributors": [
    {
      "name": "Antonio Fuscaldo",
      "email": "antoniofuscaldo.dev@gmail.com"
    }
  ]
}
