{
  "name": "freecodecamp",
  "type": "module",
  "version": "1.0.2",
  "description": "My freecodecamp certifications collection.",
  "author": {
    "name": "Antonio Fuscaldo",
    "email": "antoniofuscaldo.dev@gmail.com",
    "url": "https://github.com/antoniofuscaldo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp"
  },
  "homepage": "https://github.com/antoniofuscaldo/freeCodeCamp",
  "bugs": {
    "url": "https://github.com/antoniofuscaldo/freeCodeCamp/issues"
  },
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "freecodecamp",
    "certifications",
    "javascript",
    "python"
  ],
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all",
    "last 2 versions"
  ],
  "scripts": {
    "clean:all": "pnpm run clean:build && pnpm run clean:coverage && pnpm run clean:dist && pnpm run clean:node_modules",
    "clean:build": "rimraf build",
    "clean:coverage": "rimraf coverage",
    "clean:dist": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "lint": "eslint . --ext .js,.mjs,.cjs,.jsx,.ts,.tsx --cache",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "rebuild": "pnpm run clean:all && pnpm install"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1"
  },
  "overrides": {},
  "contributors": [
    {
      "name": "Antonio Fuscaldo",
      "email": "antoniofuscaldo.dev@gmail.com"
    }
  ]
}
